@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <!-- Welcome Section -->
    <header class="welcome-section">
        <h1>Municipality Management System</h1>
        <p>Efficiently manage service requests, reports, citizens and staff.</p>
    </header>

    <!-- Navigation Buttons -->
    <div class="buttons-container">
        <a href="@Url.Action("Index", "ServiceRequest")" class="custom-btn btn-blue">Manage Service Requests</a>
        <a href="@Url.Action("Index", "Report")" class="custom-btn btn-green">View Reports</a>
        <a href="@Url.Action("Index", "Citizen")" class="custom-btn btn-orange">Manage Citizens</a>
        <a href="@Url.Action("Index", "Staff")" class="custom-btn btn-red">Manage Staff</a>
    </div>

    <hr class="divider">

    <!-- About Us Section -->
    <section id="about" class="info-section">
        <h2>About Us</h2>
        <p>
            We are dedicated to providing an efficient platform for managing municipal services and citizen engagement.
            Our system ensures smooth handling of service requests, report tracking, and citizen management.
        </p>
    </section>

    <hr class="divider">

    <!-- Contact Us Section -->
    <section id="contact" class="info-section">
        <h2>Contact Us</h2>
        <p>Have a question? Fill out the form below and we'll get back to you!</p>

        <div class="form-container">
            <form method="post" asp-action="Contact" asp-controller="Home">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="Name" required>

                <label for="email">Email Address</label>
                <input type="email" id="email" name="Email" required>

                <label for="message">Message</label>
                <textarea id="message" name="Message" rows="4" required></textarea>

                <button type="submit" class="custom-btn btn-red">Send Message</button>
            </form>
        </div>
    </section>
</div>

<!-- Custom CSS -->
<style>
    /* General Styles */
   body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: #f4f4f4;
}

/* Main Container */
.container {
    max-width: 800px;
    margin: 40px auto;
    padding: 20px;
    background: #ffffff;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    border-radius: 8px;
}

/* Welcome Section */
.welcome-section {
    text-align: center;
    padding: 20px;
    background: #0073e6;
    color: white;
    border-radius: 8px 8px 0 0;
}

.welcome-section h1 {
    margin-bottom: 10px;
    font-size: 24px;
}

/* Navigation Buttons */
.buttons-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    padding: 20px 10px;
}

.custom-btn {
    text-decoration: none;
    color: white;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: bold;
    border-radius: 5px;
    transition: background 0.3s ease-in-out;
    display: inline-block;
    text-align: center;
}

/* Button Colors */
.btn-blue { background: #0073e6; }
.btn-green { background: #28a745; }
.btn-orange { background: #ff9800; }
.btn-red { background: #dc3545; }

/* Button Hover Effects */
.custom-btn:hover {
    filter: brightness(85%);
}

/* Dividers */
.divider {
    border: 0;
    height: 2px;
    background: #ddd;
    margin: 20px 0;
}

/* Info Sections */
.info-section {
    padding: 20px;
    text-align: center;
}

.info-section h2 {
    color: #333;
}

/* Contact Form */
.form-container {
    background: #f8f9fa;
    padding: 15px;
    border-radius: 8px;
}

form {
    display: flex;
    flex-direction: column;
}

label {
    font-weight: bold;
    margin: 10px 0 5px;
}

input, textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 14px;
}

button.custom-btn {
    margin-top: 10px;
}

